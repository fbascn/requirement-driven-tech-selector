        "Majority compromise required",
        "Supermajority compromise required"
      ],
      "classes": {
        "LOW": "CRSF ≤ 0.25",
        "MID": "0.25 < CRSF ≤ 0.75",
        "HIGH": "CRSF > 0.75"
      },
      "parameterization": {
        "LOW": { "range": "CRSF ≤ 0.25" },
        "MID": { "range": "0.25 < CRSF ≤ 0.75" },
        "HIGH": { "range": "CRSF > 0.75" }
      }
    }
